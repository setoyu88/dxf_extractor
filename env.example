# OpenAI APIキー
OPENAI_API_KEY=sk-...

# Anthropic (Claude) APIキー
ANTHROPIC_API_KEY=sk-ant-...

# Azure AI Foundry
# 既定（config.yaml の llm.azure.auth_method: azure_cli）は Azure CLI 認証（az login）を
# 使用するため APIキーは不要。endpoint/deployment/api_version は config.yaml の llm.azure で指定する。
# 下記は auth_method: api_key を選ぶ場合のみ設定する。
# AZURE_OPENAI_API_KEY=...
